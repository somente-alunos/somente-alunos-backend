{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-16",
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
	"compatibility_flags": ["nodejs_compat"],

	"env": {
		// # # # # # # # # # # # # # # # # # # # #
		// Env Production
		"production": {
			// Name Production
			"name": "somente-alunos-backend",

			// Routes Production
			"routes": [
				{
					"pattern": "api.somentealunos.vip",
					"custom_domain": true,
				},
			],

			// D1 Production
			"d1_databases": [
				{
					"binding": "D1_somenteAlunosAll2",
					"database_name": "d1_somente_alunos_all_2-production",
					"database_id": "6158fe23-a31e-462a-ac58-70415ae0909d",
					"preview_database_id": "55bf0f16-bf4d-46ae-98cc-cfe66d98f394",
				},
			],

			// R2 Production
			"r2_buckets": [
				{
					"binding": "R2_somenteAlunosAll2",
					"bucket_name": "somente-alunos-all-2-production",
					"preview_bucket_name": "somente-alunos-all-2-dev",
				},
			],

			// Mtls Certificates Production
			"mtls_certificates": [
				{
					"binding": "MtlsCertificates_efiBankGP",
					"certificate_id": "b3812965-73a2-46b2-a9b2-729cc13ca66f",
					"remote": true,
				},
				{
					"binding": "MtlsCertificates_efiBankRP",
					"certificate_id": "bda6ec26-9536-4eb6-980c-2140cf781258",
					"remote": true,
				},
				{
					"binding": "MtlsCertificates_efiBankRC",
					"certificate_id": "cbd1aa0d-a2cf-4f03-aca4-360cfeb6725e",
					"remote": true,
				},
			],

			// Var Production
			"vars": {
				"Env_originFrontend": "https://somentealunos.vip",
				"Env_hostnameFrontend": "somentealunos.vip",
				"Env_cookiePrefix": "production",
				"Env_environment": "production",

				// Variables Secrets (They can be set here or in a .env.production file)
				/* "EnvSecret_verifyStudentCpfOrRa": true,

				"EnvSecret_verifyStudentEndpoint1": "https://example-external-api-to-verify-student-document.com/verify_1",
				"EnvSecret_verifyStudentEndpoint2": "https://example-external-api-to-verify-student-document.com/verify_2",
				"EnvSecret_verifyStudentEndpoint3": "https://example-external-api-to-verify-student-document.com/verify_3",

				"EnvSecret_verifyStudentToken1": "example_secretToken",
				"EnvSecret_verifyStudentToken2": "example_secretToken",
